    {
      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE TABLE IF NOT EXISTS public.ray_chat_history (\n  id BIGSERIAL PRIMARY KEY,\n  session_id TEXT NOT NULL,\n  message_type TEXT NOT NULL CHECK (message_type IN ('user', 'assistant')),\n  content TEXT NOT NULL,\n  source TEXT,\n  confidence TEXT,\n  created_at TIMESTAMPTZ DEFAULT NOW()\n);\n\nCREATE INDEX IF NOT EXISTS idx_ray_chat_history_session_created_at\nON public.ray_chat_history (session_id, created_at DESC);",
        "options": {}
      },
      "id": "c6b3034f-fc9e-46ff-9458-b512ad60af52",
