    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.ray_chat_history (session_id, message_type, content, source, confidence, created_at)\nVALUES (\n  '{{ (($json.sessionId || $('Edit Fields').first().json.sessionId || '') + '').replaceAll(\"'\", \"''\") }}',\n  'user',\n  '{{ (($json.chatInput || $('Edit Fields').first().json.chatInput || '') + '').replaceAll(\"'\", \"''\") }}',\n  NULL,\n  NULL,\n  NOW()\n);",
        "options": {}
      },
